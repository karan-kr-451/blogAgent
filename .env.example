# Autonomous Blog Agent Configuration
# Copy this file to .env and fill in your actual values

# Medium API Configuration (OPTIONAL)
# Leave empty to save blog posts locally as markdown files
MEDIUM_API_TOKEN=
MEDIUM_AUTHOR_ID=

# DEV.to Configuration (OPTIONAL)
# Leave empty to save blog posts locally as markdown files
# Get your API key: https://dev.to/settings/extensions → "DEV API Keys" → New Key
DEVTO_API_TOKEN=
PUBLISH_TO_DEVTO=false  # Set to true to enable DEV.to publishing (requires valid token)

# Publishing Configuration
PUBLISH_TO_MEDIUM=false  # Set to true to enable Medium publishing (requires valid token)
LOCAL_DRAFTS_DIR=drafts  # Directory to save local draft blog posts

# Ollama Configuration
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma:7b
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2000
OLLAMA_TIMEOUT=120

# Crawler Configuration
CRAWLER_START_URL=https://blog.bytebytego.com
CRAWLER_MAX_ACTIONS=50
CRAWLER_HEADLESS=true

# Memory System Configuration
MEMORY_INDEX_PATH=memory/vectors.index
MEMORY_METADATA_PATH=memory/metadata.json
DUPLICATE_THRESHOLD=0.85

# Review Configuration
REVIEW_SIMILARITY_THRESHOLD=0.70

# Content Generation Configuration
MIN_WORD_COUNT=800
MAX_WORD_COUNT=1500
MAX_REGENERATION_ATTEMPTS=2

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0

# Scheduler Configuration
SCHEDULE_TIME=09:00
SCHEDULE_ENABLED=true

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
