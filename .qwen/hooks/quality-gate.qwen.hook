{
  "version": "1.0.0",
  "enabled": true,
  "name": "quality-gate",
  "description": "Run a full quality gate check (ruff, mypy, black, pytest, property tests) for BlogAgent. Trigger manually from the Agent Hooks panel.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "cmd /c \"ruff check src/ && mypy src/ && black --check src/ && pytest --cov=src --cov-report=term-missing -v\""
  }
}